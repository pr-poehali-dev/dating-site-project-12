{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "register",
        "email": "test_spark_777@example.com",
        "password": "password123",
        "name": "Тест",
        "age": 25,
        "city": "Москва",
        "bio": "Тестовый пользователь",
        "interests": ["Музыка", "Кино"]
      },
      "expectedStatus": 201,
      "expectedBody": { "token": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Login existing user",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "login",
        "email": "test_spark_777@example.com",
        "password": "password123"
      },
      "expectedStatus": 200,
      "expectedBody": { "token": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "login",
        "email": "test_spark_777@example.com",
        "password": "wrongpass"
      },
      "expectedStatus": 401,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    }
  ]
}
